<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://bmicc.cn/IBD_py2ontove.owl"
         xmlns="http://bmicc.cn/IBD_py2ontove.owl#">

<owl:Ontology rdf:about="#"/>

<owl:ObjectProperty rdf:about="#hasSymptom">
  <owl:inverseOf rdf:resource="#isSymptomOf"/>
  <rdfs:domain rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:range rdf:resource="#Symptom"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">has symptom</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD has symptoms.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#leadsTo">
  <rdfs:domain rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:range rdf:resource="#Complication"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">leads to</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD can lead to complications.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isSymptomOf">
  <owl:inverseOf rdf:resource="#hasSymptom"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">is symptom of</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#affects">
  <rdfs:domain rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">affects</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD affects the intestines.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#increasesRiskOf">
  <rdfs:domain rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:range rdf:resource="#MentalHealthChallenge"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">increases risk of</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD increases risk of mental health challenges.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isGIComplicationOf">
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">is GI complication of</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#treatedBy">
  <rdfs:domain rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">treated by</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD is treated by medications and surgery.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasPhase">
  <rdfs:domain rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:range rdf:resource="#DiseasePhase"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">has phase</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD has phases of remission and flare-up.</rdfs:comment>
</owl:ObjectProperty>

<owl:AnnotationProperty rdf:about="#definition">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">definition</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The authoritative definition of an ontology term</rdfs:comment>
</owl:AnnotationProperty>

<owl:AnnotationProperty rdf:about="#hasDbXref">
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label rdf:datatype="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString">has dbxref</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Database cross-reference to an external resource (e.g., SNOMED CT, MeSH, NCIT)</rdfs:comment>
</owl:AnnotationProperty>

<owl:Class rdf:about="#Symptom">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label xml:lang="en">Symptom</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD symptoms can range from mild to severe.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Diarrhea">
  <rdfs:subClassOf rdf:resource="#Symptom"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isSymptomOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Diarrhea</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Common symptom of IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#StomachPain">
  <rdfs:subClassOf rdf:resource="#Symptom"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isSymptomOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Stomach Pain</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Common symptom of IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Fatigue">
  <rdfs:subClassOf rdf:resource="#Symptom"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isSymptomOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Fatigue</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Common symptom of IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Nausea">
  <rdfs:subClassOf rdf:resource="#Symptom"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isSymptomOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Nausea</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Common symptom of IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#WeightLoss">
  <rdfs:subClassOf rdf:resource="#Symptom"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isSymptomOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Weight Loss</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Common symptom of IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#DiseasePhase">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label xml:lang="en">Disease Phase</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Symptoms come and go in waves.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Remission">
  <rdfs:subClassOf rdf:resource="#DiseasePhase"/>
  <rdfs:label xml:lang="en">Remission</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Periods when symptoms temporarily go away.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#FlareUp">
  <rdfs:subClassOf rdf:resource="#DiseasePhase"/>
  <rdfs:label xml:lang="en">Flare-up</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Periods of increased symptoms.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Complication">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label xml:lang="en">Complication</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD can lead to health complications both inside the GI tract and outside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#GastrointestinalComplication">
  <rdfs:subClassOf rdf:resource="#Complication"/>
  <rdfs:label xml:lang="en">Gastrointestinal Complication</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complications inside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Dehydration">
  <rdfs:subClassOf rdf:resource="#GastrointestinalComplication"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isGIComplicationOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Dehydration</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complication inside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Malabsorption">
  <rdfs:subClassOf rdf:resource="#GastrointestinalComplication"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isGIComplicationOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Malabsorption</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not absorbing enough essential nutrients.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#IncreasedCancerRisk">
  <rdfs:subClassOf rdf:resource="#GastrointestinalComplication"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isGIComplicationOf"/>
      <owl:someValuesFrom rdf:resource="#InflammatoryBowelDisease"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Increased Cancer Risk</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Increased risk of colon and rectal cancers.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#ExtraintestinalManifestation">
  <rdfs:subClassOf rdf:resource="#Complication"/>
  <rdfs:label xml:lang="en">Extraintestinal Manifestation</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complications outside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Anemia">
  <rdfs:subClassOf rdf:resource="#ExtraintestinalManifestation"/>
  <rdfs:label xml:lang="en">Anemia</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low red blood cell count.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#ReducedBoneDensity">
  <rdfs:subClassOf rdf:resource="#ExtraintestinalManifestation"/>
  <rdfs:label xml:lang="en">Reduced Bone Density</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complication outside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#JointPain">
  <rdfs:subClassOf rdf:resource="#ExtraintestinalManifestation"/>
  <rdfs:label xml:lang="en">Joint Pain</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complication outside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SkinChanges">
  <rdfs:subClassOf rdf:resource="#ExtraintestinalManifestation"/>
  <rdfs:label xml:lang="en">Skin Changes</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complication outside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EyeIrritation">
  <rdfs:subClassOf rdf:resource="#ExtraintestinalManifestation"/>
  <rdfs:label xml:lang="en">Eye Irritation</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complication outside the GI tract.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#DelayedGrowth">
  <rdfs:subClassOf rdf:resource="#ExtraintestinalManifestation"/>
  <rdfs:label xml:lang="en">Delayed Growth</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Delayed or impaired growth in some children.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#MentalHealthChallenge">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label xml:lang="en">Mental Health Challenge</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBD can impact a person's quality of life, increasing the risk of mental health challenges.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Depression">
  <rdfs:subClassOf rdf:resource="#MentalHealthChallenge"/>
  <rdfs:label xml:lang="en">Depression</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mental health challenge associated with IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Anxiety">
  <rdfs:subClassOf rdf:resource="#MentalHealthChallenge"/>
  <rdfs:label xml:lang="en">Anxiety</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mental health challenge associated with IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Distress">
  <rdfs:subClassOf rdf:resource="#MentalHealthChallenge"/>
  <rdfs:label xml:lang="en">Distress</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feelings of distress or being overwhelmed.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#OtherMentalDisorder">
  <rdfs:subClassOf rdf:resource="#MentalHealthChallenge"/>
  <rdfs:label xml:lang="en">Other Mental Disorder</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Other mental disorders associated with IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Medication">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label xml:lang="en">Medication</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Common medications for IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Aminosalicylate">
  <rdfs:subClassOf rdf:resource="#Medication"/>
  <rdfs:label xml:lang="en">Aminosalicylate</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">These help reduce inflammation in the digestive tract. Also called 5-aminosalicylic acids or 5-ASA.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Corticosteroid">
  <rdfs:subClassOf rdf:resource="#Medication"/>
  <rdfs:label xml:lang="en">Corticosteroid</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Strong anti-inflammatory steroids that work fast.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Immunomodulator">
  <rdfs:subClassOf rdf:resource="#Medication"/>
  <rdfs:label xml:lang="en">Immunomodulator</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">These block the immune reaction that leads to inflammation. Also called immunosuppressive agents.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Biologic">
  <rdfs:subClassOf rdf:resource="#Medication"/>
  <rdfs:label xml:lang="en">Biologic</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">These block the immune system chemicals that trigger inflammation. Made from living sources.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Treatment">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label xml:lang="en">Treatment</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treatments for IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Surgery">
  <rdfs:subClassOf rdf:resource="#Treatment"/>
  <rdfs:label xml:lang="en">Surgery</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be done to remove or widen the areas of the intestines that have been severely affected.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="http://purl.obolibrary.org/obo/MONDO_0000001">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:label xml:lang="en">disease</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#InflammatoryBowelDisease">
  <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MONDO_0000001"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#affects"/>
      <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasSymptom"/>
      <owl:someValuesFrom rdf:resource="#Diarrhea"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasSymptom"/>
      <owl:someValuesFrom rdf:resource="#Fatigue"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasSymptom"/>
      <owl:someValuesFrom rdf:resource="#Nausea"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasSymptom"/>
      <owl:someValuesFrom rdf:resource="#StomachPain"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasSymptom"/>
      <owl:someValuesFrom rdf:resource="#WeightLoss"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasPhase"/>
      <owl:someValuesFrom rdf:resource="#DiseasePhase"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#leadsTo"/>
      <owl:someValuesFrom rdf:resource="#Complication"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#increasesRiskOf"/>
      <owl:someValuesFrom rdf:resource="#MentalHealthChallenge"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#treatedBy"/>
      <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">Inflammatory Bowel Disease</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inflammatory bowel disease (IBD) refers to a group of lifelong diseases affecting the intestines.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#UlcerativeColitis">
  <rdfs:subClassOf rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:label xml:lang="en">Ulcerative Colitis</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A main type of IBD.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#CrohnsDisease">
  <rdfs:subClassOf rdf:resource="#InflammatoryBowelDisease"/>
  <rdfs:label xml:lang="en">Crohn's Disease</rdfs:label>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A main type of IBD.</rdfs:comment>
</owl:Class>


</rdf:RDF>
